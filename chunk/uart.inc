* Control (write)
C_NONE		EQU	%00000000
C_TX_IRQ	EQU	%00000010
C_RESET		EQU	%00001000
C_RX_IRQ	EQU	%00100000


* Status (read)
S_TX_EMPTY	EQU	%00000001
S_TX_IRQ	EQU	%00000010
S_BUSY		EQU	%00001000
S_RX_FULL	EQU	%00010000
S_RX_IRQ	EQU	%00100000

INIT	EXTERN
PUTS	EXTERN
PUTCHAR	EXTERN
PUTCRLF	EXTERN
GETS	EXTERN
OUTCH	EXTERN
INCH	EXTERN

UARTC	EXTERN
UARTS	EXTERN
UARTTX	EXTERN
UARTRX	EXTERN
